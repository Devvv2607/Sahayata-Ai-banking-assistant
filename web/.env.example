# Sahayata AI — frontend (web/) environment. Copy to .env.local and fill in real values.
# Only NEXT_PUBLIC_* values are exposed to the browser. NEVER put server secrets here.

# Base URL of the FastAPI backend (Cloud Run URL in production).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Supabase (public, browser-safe values only).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
