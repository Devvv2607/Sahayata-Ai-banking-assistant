# Sahayata AI — backend (api/) environment. Copy to .env and fill in real values.
# NEVER commit a real .env file.

# --- App ---
APP_ENV=development                       # development | production
LOG_LEVEL=INFO
# Comma-separated list of allowed origins for CORS (NO wildcards in production).
CORS_ALLOW_ORIGINS=http://localhost:3000

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # backend only; never expose to the browser
SUPABASE_JWT_AUDIENCE=authenticated

# --- Google Cloud / Vertex AI (Gemini) ---
GCP_PROJECT_ID=your-gcp-project
GCP_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GEMINI_MODEL=gemini-2.0-flash             # Flash by default for cost control
GEMINI_SUMMARY_MODEL=gemini-2.0-pro       # Pro for higher-quality summaries

# --- Sarvam AI (speech + translation) ---
SARVAM_API_KEY=your-sarvam-key

# --- Provider toggles (swap vendors without code changes) ---
SPEECH_PROVIDER=sarvam                     # sarvam | google | fake
TRANSLATION_PROVIDER=sarvam                # sarvam | gemini | google | fake
LLM_PROVIDER=gemini                        # gemini | fake

# --- Cost / safety guardrails ---
MAX_AUDIO_BYTES=5242880                    # 5 MB upload cap
MAX_AUDIO_SECONDS=30                       # per-turn audio length cap
RATE_LIMIT_TURNS=20/minute                 # per-client rate limit on AI endpoints
